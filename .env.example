# Copy to .env and set strong passwords before: docker compose up -d

MYSQL_ROOT_PASSWORD=change-this-root-password
MYSQL_DATABASE=enurcnc_db
MYSQL_USER=enurcnc
MYSQL_PASSWORD=change-this-app-password

# Local port for the web app
APP_PORT=8080

# Tag when using a pre-built image from Docker Hub
APP_IMAGE_TAG=latest
