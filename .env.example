# Sunucuda /root/enurcnc/.env olarak kopyala ve düzenle.
#
# Uygulama DB kullanıcısı — yedekteki düz metin şifre burada:
#   C:\development\backup-enurcnc\homedir\public_html\dsm\system\settings.php
# (enurcnc_db.sql içinde şifre yok; mysql.sql sadece hash içerir.)

# MySQL root — yedekte yok; güçlü bir değer ver (Docker imajı oluşturur).
MYSQL_ROOT_PASSWORD=buraya-guclu-root-sifre

MYSQL_DATABASE=enurcnc_db
MYSQL_USER=enurcnc_user2
# Özel karakterler için tırnak kullan
MYSQL_PASSWORD="Y6IE}jyzgtkc"

# Prod: app 127.0.0.1:8080 (docker-compose.prod.yml); dışarıdan Nginx 80/443.
APP_IMAGE_TAG=latest
