RewriteCond %{HTTPS} on
RewriteCond %{HTTP_HOST} !^www\. [NC]
RewriteRule .* https://www.%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
# HTTP -> HTTPS yalnızca alan adı ile; ham IPv4 veya IP:port (Docker / geçici VPS IP) TLS dinlemediğinde kırılmaz.
RewriteCond %{SERVER_PORT} 80
RewriteCond %{HTTP_HOST} !^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+(:[0-9]+)?$ [NC]
RewriteRule ^.*$ https://%{SERVER_NAME}%{REQUEST_URI} [R=301,L]

#Page Seo Url Edit

RewriteCond %{SCRIPT_FILENAME} !-d
RewriteRule ^sitemap.xml$ sitemap.php [NC,L]
RewriteRule ^404$ 404.php [NC]

##### Kurumsal #####
RewriteRule ^kurumsal$ kurumsal.php [NC]
RewriteRule ^insan-kaynaklari$ ik.php [NC]
RewriteRule ^sertifikalar$ sertifikalar.php [NC]
RewriteRule ^is-sagligi-guvenligi$ is_guvenligi.php [NC]
RewriteRule ^referanslar$ is-ortaklarimiz.php [NC]
RewriteRule ^cevre-politikasi$ cevre_politikasi.php [NC]
RewriteRule ^lojistik-guvenligi$ lojistik_guvenligi.php [NC]
RewriteRule ^kalite-politikasi$ kalite_politikasi.php [NC]
RewriteRule ^kvkk$ kvkk.php [NC]
RewriteRule ^cerez-politikasi$ cerez_politikasi.php [NC]

##### Resmi Sayfalar #####
RewriteRule ^cerez-politikasi$ cerez_politikasi.php [NC]
RewriteRule ^kvkk$ kvkk.php [NC]
RewriteRule ^calismalar$ calismalar.php [NC]
RewriteRule ^hakkimizda$ hakkimizda.php [NC]
RewriteRule ^aydinlatma-metni$ aydinlatma_metni.php [NC]
RewriteRule ^kamera-aydinlatma-metni$ kamera_aydinlatma_metni.php [NC]
RewriteRule ^veri-sorumlusuna-basvuru-formu$ veri_sorumlusu_basvuru_formu.php [NC]

##### Urunler #####
RewriteRule ^urun/([a-zA-Z0-9\-_]+)?$ urun-detay.php?seo=$1 [L,NC]

##### Kullanim Alanlari #####
RewriteRule ^hizmetler$ kullanim-alanlari.php [NC]
RewriteRule ^hizmet/([a-zA-Z0-9\-_]+)?$ kullanim-alani.php?seo=$1 [L,QSA]

##### İş Ortakları #####
##### RewriteRule ^referanslar$ is-ortaklarimiz.php [NC]
##### RewriteRule ^is-ortagi/([a-zA-Z0-9\-_]+)?$ is-ortaklari-detay.php?seo=$1 [L,QSA]

##### Medya #####
#####RewriteRule ^haberler$ medya-basin.php [NC]
#####RewriteRule ^haber/([a-zA-Z0-9\-_]+)?$ medya-detay.php?seo=$1 [L,QSA]
RewriteRule ^sektorler$ medya-basin.php [NC]
RewriteRule ^sektor/([a-zA-Z0-9\-_]+)?$ medya-detay.php?seo=$1 [L,QSA]
#####RewriteRule ^fuarlar$ medya-basin.php [NC]
#####RewriteRule ^fuar/([a-zA-Z0-9\-_]+)?$ medya-detay.php?seo=$1 [L,QSA]

#####RewriteRule ^kataloglar$ kataloglar.php [L,NC]
#####RewriteRule ^sertifikalar$ sertifikalar.php [L,NC]
#####RewriteRule ^tanitim-filmleri$ tanitim_filmleri.php [L,NC]
#####RewriteRule ^fuarlar$ fuarlar.php [L,NC]
RewriteRule ^iletisim$ iletisim.php [NC]

RewriteRule ^hata-([a-zA-Z0-9\-_]+)?$ error.php?seo=$1 [L,QSA]

##### Kategoriler #####
RewriteRule ^urunler$ kategori.php?seo=urunler [L,QSA]
RewriteRule ^urunler/([a-zA-Z0-9\-_]+)?$ kategori.php?seo=$1 [L,QSA]

# Yerel sayfa: favicon vb. 404 olduğunda dış domaine yönlendirmeyin (timeout / beyaz sayfa).
ErrorDocument 400 /404.php
