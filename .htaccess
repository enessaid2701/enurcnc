#Settings
Options All -Indexes

<files .htaccess>
order allow,deny
deny from all
</files>
<files parts/footer.php>
order allow,deny
deny from all
</files>
<files parts/head.php>
order allow,deny
deny from all
</files>
<files parts/header.php>
order allow,deny
deny from all
</files>
<files parts/infrastructure.php>
order allow,deny
deny from all
</files>

